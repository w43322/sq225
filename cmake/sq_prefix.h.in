/*
 * Force-included before every translation unit.
 * Pulls in C++ standard library headers BEFORE sqobject.h
 * defines `#define type(obj)` which collides with <limits> etc.
 *
 * This file is NOT part of the original Squirrel source.
 * It is generated by CMake and injected via -include.
 */
